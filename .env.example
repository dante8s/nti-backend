# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Database (local Docker defaults — fine for development) ───────────────────
DB_NAME=nti_db
DB_USERNAME=user
DB_PASSWORD=password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required — min 32 chars; generate with: openssl rand -hex 32
JWT_SECRET=
# Optional — token lifetime in milliseconds (default: 86400000 = 24 h)
# JWT_EXPIRATION_MS=86400000

# ── Email ─────────────────────────────────────────────────────────────────────
# Dev:  use Mailtrap — https://mailtrap.io → Inboxes → SMTP Settings
# Prod: use Gmail — App Password (not your regular password):
#       myaccount.google.com → Security → App passwords
#
# Dev (Mailtrap):
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_FROM=noreply@nti.sk
#
# Prod (Gmail) — uncomment and fill in:
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-gmail@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_FROM=your-gmail@gmail.com

# Email address that receives admin notifications (e.g. "new user registered").
# Can be any address — does not have to match MAIL_FROM.
MAIL_ADMIN=your-admin-email@example.com

# ── reCAPTCHA v2 ──────────────────────────────────────────────────────────────
# https://www.google.com/recaptcha/admin → register site → Secret key
RECAPTCHA_SECRET=your-recaptcha-v2-secret-key

# ── Application URLs ──────────────────────────────────────────────────────────
# Docker: backend is reachable on port 8080, frontend on port 3000
APP_BACKEND_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:3000
